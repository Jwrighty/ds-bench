{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "base": {
    "color": {
      "primary": { "$type": "color", "$value": "#3366ff" },
      "secondary": { "$type": "color", "$value": "#6633ff" },
      "surface": { "$type": "color", "$value": "#ffffff" }
    },
    "space": {
      "sm": { "$type": "dimension", "$value": "4px" },
      "md": { "$type": "dimension", "$value": "8px" },
      "lg": { "$type": "dimension", "$value": "16px" }
    },
    "font": {
      "size": {
        "sm": { "$type": "dimension", "$value": "12px" },
        "md": { "$type": "dimension", "$value": "16px" },
        "2xl": { "$type": "dimension", "$value": "24px" },
        "3xl": { "$type": "dimension", "$value": "30px" },
        "2Xl": { "$type": "dimension", "$value": "40px" }
      },
      "lineHeight": {
        "tight": { "$type": "number", "$value": 1.1 }
      }
    }
  }
}
